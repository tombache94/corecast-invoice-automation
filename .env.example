# Microsoft Graph (Azure AD app registration with Mail.Read + Mail.Send application permissions)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Mailboxes to monitor (comma-separated UPNs)
MAILBOXES=tom@corecastconcrete.com.au,accounts@corecastconcrete.com.au

# How many recent messages to scan per poll
MAILBOX_FETCH_LIMIT=50

# Connecteam (kept for potential future use — main flow uses XLSX export)
CONNECTEAM_API_KEY=
CONNECTEAM_BASE_URL=https://api.connecteam.com
# Note: the API time clock ID (16246267) differs from the punch-clock UI ID (13723871)
CONNECTEAM_TIME_CLOCK_ID=16246267

# Local storage
INVOICES_FILE=./data/invoices.json

# Folder where Connecteam XLSX exports are dropped each week
TIMESHEETS_FOLDER=./timesheets

# Email report settings
REPORT_RECIPIENT=tom@corecastconcrete.com.au
REPORT_SENDER=accounts@corecastconcrete.com.au

# Tolerance in hours before flagging a mismatch (default 0.5)
HOURS_TOLERANCE=0.5

# Email attachment filing — uploads to SharePoint by job keyword
# Drive ID is the CORECAST SharePoint drive (default works for the existing tenant).
SHAREPOINT_DRIVE_ID=b!4B_dBjoPKEeuMh4XWxgxCQcyBxLlmwFLgtOWOYvkPTQGCZjiE9CmRoLS7JMod59t
# Library paths inside the drive (override if SharePoint structure changes).
SHAREPOINT_ACTIVE_JOBS_PATH=CORECAST/📁 ACTIVE JOBS
SHAREPOINT_ACTIVE_QUOTES_PATH=CORECAST/📋 QUOTES/Active Quotes
SHAREPOINT_TO_SORT_PATH=CORECAST/To Sort
SHAREPOINT_ACCOUNTS_PAYABLE_PATH=CORECAST/Accounts Payable
# Keyword → folder map (edit this file to add new jobs)
JOB_KEYWORDS_FILE=./config/job-keywords.json
# Supplier domain → folder map (edit to add suppliers; routes their attachments to AP)
SUPPLIER_DOMAINS_FILE=./config/supplier-domains.json
# Where filing state is persisted (so re-runs don't re-upload)
FILING_STATE_FILE=./data/filed-attachments.json
# Notification email when an attachment can't be auto-filed
# Comma-separated list of digest-email recipients (one email per run goes to all)
FILING_NOTIFY_RECIPIENT=tom@corecastconcrete.com.au,josh@corecastconcrete.com.au
FILING_NOTIFY_SENDER=accounts@corecastconcrete.com.au
FILING_FETCH_LIMIT=50
# Default rolling window when --since is not passed. The script will scan emails
# received in the last N hours. Combined with the dedup state file, this is safe
# to overlap on a recurring schedule (e.g. run every 30min with a 24h lookback).
FILING_LOOKBACK_HOURS=24
# Comma-separated sender domains to skip entirely (internal forwards never
# need to be auto-filed and would otherwise spam the digest).
FILING_SKIP_DOMAINS=corecastconcrete.com.au

# Xero OAuth2 credentials (custom connection app at https://developer.xero.com)
# Run `node scripts/xero-auth.js` once to populate XERO_REFRESH_TOKEN.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=024c8088-8095-482b-906e-f72d9b8acaee
XERO_REFRESH_TOKEN=
# Cache file for the rotating refresh token (kept up-to-date by the client)
XERO_TOKEN_CACHE=./data/xero-token.json

# Cloudflare Pages — public dashboard mirror (token at https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=corecast-dashboard
